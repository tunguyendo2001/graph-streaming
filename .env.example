# Memgraph Bolt endpoint
MEMGRAPH_URI=bolt://localhost:7687

# Memgraph local mặc định thường không bật auth.
# Nếu bạn bật authentication, điền user/password ở đây.
MEMGRAPH_USER=
MEMGRAPH_PASSWORD=

# CERT r4.2 streaming graph replay
CERT_STREAM_JSONL=artifacts/evaluation_stream.jsonl
CERT_STREAM_DELAY_SECONDS=0
CALIBRATION_DAYS=30
ALLOWED_LATENESS_SECONDS=300
PRUNE_AFTER_DAYS=90
UC1_FALLBACK_THRESHOLD=0.75
UC2_FALLBACK_THRESHOLD=0.75
REPLAY_SUMMARY_JSON=artifacts/replay_summary.json
